{
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(node .gemini/hooks/*)",
      "Bash(bash .gemini/hooks/*)",
      "Bash(sh .gemini/hooks/*)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(cat *)",
      "Bash(tree *)",
      "Bash(grep *)",
      "Bash(mkdir *)",
      "Bash(mv *)",
      "Bash(cp *)",
      "Bash(rm *)",
      "Bash(chmod *)",
      "Bash(jq *)",
      "Bash(wc *)",
      "Bash(date *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(python3 *)",
      "Bash(python *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git pull *)",
      "Bash(git stash *)",
      "Bash(git worktree *)",
      "Bash(gh pr *)",
      "Bash(ln -sf session-state_2026-03-27.md session-state_LATEST.md)",
      "Bash(ln:*)",
      "Bash(for skill:*)",
      "Bash(do)",
      "Bash(echo \"=== $skill ===\")",
      "Read(/./02_MACHINE/Research/everything-claude-code/skills/$skill/**)",
      "Bash(done)",
      "Bash(npm show:*)",
      "Bash(claude mcp:*)",
      "Bash(npx -y mcp-excalidraw-server --version)",
      "Bash(curl:*)",
      "Bash(npm root:*)",
      "Bash(find [REDACTED_LOCAL_PATH]/Documents/V.A.N.T.i.S -type f \\\\\\(-name *.sh -o -name *.plist -o -name *startup* -o -name *server* \\\\\\))",
      "Bash(npm list:*)",
      "Bash(npm view:*)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:api.github.com)",
      "Bash(npm ci:*)",
      "Bash(npm run:*)",
      "Bash(mkdir -p ~/.local/share/mcp-excalidraw/logs)",
      "Bash(launchctl load:*)",
      "Bash(launchctl unload:*)",
      "Bash(curl -s -X POST http://localhost:3000/api/elements/batch -H \"Content-Type: application/json\" -d '{:*)",
      "WebFetch(domain:github.com)",
      "Read(//private/tmp/**)",
      "Bash(npx uipro-cli:*)",
      "Bash(cp:*)",
      "WebSearch",
      "Read(/[REDACTED_LOCAL_PATH]/**)",
      "Bash(npx -y excalidraw-mcp --help)",
      "mcp__excalidraw__snapshot_scene",
      "mcp__excalidraw__read_diagram_guide",
      "mcp__excalidraw__clear_canvas",
      "mcp__excalidraw__batch_create_elements",
      "mcp__excalidraw__set_viewport",
      "mcp__excalidraw__get_canvas_screenshot",
      "mcp__excalidraw__describe_scene",
      "mcp__excalidraw__query_elements",
      "mcp__excalidraw__update_element",
      "mcp__excalidraw__delete_element",
      "Bash(for d:*)",
      "Bash(do echo:*)",
      "Read(/./**)",
      "Skill(update-config)",
      "Bash(afplay /System/Library/Sounds/Glass.aiff)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .gemini/hooks/repo-map.sh"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .gemini/hooks/precompact-snapshot.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash .gemini/hooks/v_observe.sh pre"
          }
        ]
      },
      {
        "matcher": "Write|Edit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .gemini/hooks/suggest-compact.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash .gemini/hooks/v_observe.sh post"
          }
        ]
      },
      {
        "matcher": "Write|Edit|NotebookEdit|Bash|run_shell_command",
        "hooks": [
          {
            "type": "command",
            "command": "bash .gemini/hooks/session-ledger.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "cd $(git rev-parse --show-toplevel) && bash .gemini/hooks/compile-audit-log.sh"
          },
          {
            "type": "command",
            "command": "cd $(git rev-parse --show-toplevel) && node .gemini/hooks/cost-tracker.js"
          }
        ]
      }
    ]
  }
}
